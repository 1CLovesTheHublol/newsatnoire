  <script>
    // Professional audio player. Editor sets <audio> src via CMS; controls work once a source exists.
    (function(){
      var audio = document.getElementById('audio');
      var playBtn = document.getElementById('playBtn');
      var fill = document.getElementById('fill');
      var knob = document.getElementById('knob');
      var scrub = document.getElementById('scrub');
      var curEl = document.getElementById('cur');
      var durEl = document.getElementById('dur');
      var rate = document.getElementById('rate');
      var rates = [1,1.25,1.5,2,0.75]; var ri = 0;

      function fmt(t){ if(isNaN(t)) return '—:—'; var m=Math.floor(t/60),s=Math.floor(t%60); return m+':'+('0'+s).slice(-2); }
      var playIcon = '<svg viewBox="0 0 24 24" fill="currentColor"><path d="M8 5v14l11-7z"></path></svg>';
      var pauseIcon = '<svg viewBox="0 0 24 24" fill="currentColor"><rect x="6" y="5" width="4" height="14"></rect><rect x="14" y="5" width="4" height="14"></rect></svg>';

      playBtn.addEventListener('click', function(){
        if(!audio.src){ return; } // no recording uploaded yet
        if(audio.paused){ audio.play(); } else { audio.pause(); }
      });
      audio.addEventListener('play', function(){ playBtn.innerHTML = pauseIcon; });
      audio.addEventListener('pause', function(){ playBtn.innerHTML = playIcon; });
      audio.addEventListener('loadedmetadata', function(){ durEl.textContent = fmt(audio.duration); });
      audio.addEventListener('timeupdate', function(){
        var p = audio.duration ? (audio.currentTime/audio.duration)*100 : 0;
        fill.style.width = p+'%'; knob.style.left = p+'%'; curEl.textContent = fmt(audio.currentTime);
      });
      scrub.addEventListener('click', function(e){
        if(!audio.duration) return;
        var r = scrub.getBoundingClientRect();
        audio.currentTime = ((e.clientX - r.left)/r.width) * audio.duration;
      });
      rate.addEventListener('click', function(){
        ri = (ri+1)%rates.length; audio.playbackRate = rates[ri]; rate.textContent = rates[ri]+'×';
      });
    })();
  </script>

