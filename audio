<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="utf-8">
<meta name="viewport" content="width=device-width, initial-scale=1">
<title>Audio — News At Noire</title>
<style>
  :root{
    --cream:#F4F1EA;--cream-2:#EDE8DC;--ink:#1A1A1A;--maroon:#6E1423;--maroon-2:#8A1E2F;
    --muted:#6b6256;--serif:Georgia,'Times New Roman',Times,serif;
    --sans:'Helvetica Neue',Arial,Helvetica,sans-serif;
  }
  *{margin:0;padding:0;box-sizing:border-box}
  html{scroll-behavior:smooth}
  body{background:var(--cream);color:var(--ink);font-family:var(--serif);line-height:1.5;-webkit-font-smoothing:antialiased}
  a{color:inherit;text-decoration:none}
  button{font-family:inherit}

  .topbar{position:sticky;top:0;z-index:50;background:rgba(244,241,234,.92);backdrop-filter:saturate(120%) blur(6px);border-bottom:1px solid var(--ink)}
  .topbar-inner{max-width:1180px;margin:0 auto;padding:12px clamp(16px,3vw,24px);display:flex;flex-wrap:wrap;align-items:center;gap:10px clamp(12px,2vw,28px)}
  .brandmark{order:1;font-family:var(--serif);font-size:clamp(1.02rem,1.4vw,1.2rem);letter-spacing:.02em;white-space:nowrap}
  .brandmark em{font-style:italic;color:var(--maroon)}
  .nav-links{order:3;flex-basis:100%;display:flex;flex-wrap:wrap;align-items:center;justify-content:center;gap:clamp(9px,1vw,14px);row-gap:8px;padding-top:11px;border-top:1px solid rgba(26,26,26,.16)}
  .nav-links a{font-family:var(--sans);font-size:clamp(.6rem,.72vw,.68rem);letter-spacing:.13em;text-transform:uppercase;color:var(--ink);padding:4px 0;border-bottom:1px solid transparent;transition:border-color .15s,color .15s}
  .nav-links a:hover,.nav-links a[aria-current]{color:var(--maroon);border-color:var(--maroon)}
  .nav-links a.home{display:inline-flex;align-items:center;gap:7px}
  .nav-links a.home svg{width:14px;height:14px;flex:none}
  .nav-links a + a::before{content:"\2022";margin-right:clamp(9px,1vw,14px);color:var(--ink);opacity:.5;font-size:.5rem;line-height:1;vertical-align:middle}
  .nav-cta{order:2;margin-left:auto;flex:none;position:relative;overflow:hidden;isolation:isolate;font-family:var(--sans);font-size:.7rem;letter-spacing:.16em;text-transform:uppercase;background:var(--maroon);border:1px solid var(--maroon);color:var(--cream);padding:7px 16px;transition:background .15s;white-space:nowrap}
  .nav-cta:hover{background:var(--maroon-2)}
  .nav-cta::before{content:"";position:absolute;top:0;left:-130%;width:55%;height:100%;background:linear-gradient(120deg,transparent,rgba(255,255,255,.55),transparent);transform:skewX(-20deg);z-index:1}
  .nav-cta:hover::before{animation:noire-sheen .9s ease}
  .nav-cta::after{content:"";position:absolute;inset:0;z-index:1;pointer-events:none;opacity:0;background-repeat:no-repeat;background-image:radial-gradient(circle,#fff 1.1px,transparent 1.6px),radial-gradient(circle,#fff 1px,transparent 1.5px),radial-gradient(circle,#fff 1.2px,transparent 1.7px),radial-gradient(circle,#fff 1px,transparent 1.5px);background-position:18% 32%,72% 58%,44% 78%,86% 24%}
  .nav-cta:hover::after{animation:noire-sparkle 1s ease-in-out infinite}
  @keyframes noire-sheen{from{left:-130%}to{left:160%}}
  @keyframes noire-sparkle{0%,100%{opacity:0}50%{opacity:.95}}

  .kicker{font-family:var(--sans);text-transform:uppercase;letter-spacing:.24em;font-size:.68rem;color:var(--maroon)}

  .sec-masthead{max-width:1180px;margin:0 auto;padding:56px 24px 26px;text-align:center;border-bottom:1px solid var(--ink)}
  .sec-masthead .kicker{display:block;margin-bottom:16px}
  .sec-masthead h1{font-family:var(--serif);font-weight:400;font-size:clamp(2.6rem,7vw,4.6rem);line-height:1}
  .sec-masthead h1 em{font-style:italic;color:var(--maroon)}
  .sec-masthead .rule{height:2px;background:var(--ink);max-width:420px;margin:20px auto 16px}
  .sec-masthead p{font-family:var(--serif);font-style:italic;font-size:clamp(1.05rem,2.3vw,1.35rem);color:#3a352d;max-width:60ch;margin:0 auto}

  /* Featured player */
  .player-wrap{max-width:900px;margin:0 auto;padding:36px 24px 10px}
  .player{border:1px solid var(--ink);background:#fff;display:grid;grid-template-columns:180px 1fr}
  .player .art{background:linear-gradient(155deg,#230810,#4a0f1a 60%,#6E1423);border-right:1px solid var(--ink);display:flex;align-items:center;justify-content:center;color:rgba(244,241,234,.8)}
  .player .art svg{width:46px;height:46px}
  .player .pbody{padding:22px 24px}
  .player .type{font-family:var(--sans);font-size:.64rem;letter-spacing:.18em;text-transform:uppercase;color:var(--maroon);display:block;margin-bottom:8px}
  .player .pbody h2{font-family:var(--serif);font-weight:400;font-size:1.5rem;line-height:1.15;margin-bottom:6px}
  .player .pbody .desc{font-family:var(--sans);font-size:.82rem;color:var(--muted);margin-bottom:16px}
  /* Custom transport */
  .transport{display:flex;align-items:center;gap:14px}
  .transport .play{width:46px;height:46px;flex:none;border-radius:50%;background:var(--maroon);border:none;color:var(--cream);cursor:pointer;display:flex;align-items:center;justify-content:center;transition:background .15s}
  .transport .play:hover{background:var(--maroon-2)}
  .transport .play svg{width:18px;height:18px}
  .bar{flex:1}
  .scrub{position:relative;height:5px;background:rgba(26,26,26,.18);cursor:pointer}
  .scrub .fill{position:absolute;top:0;left:0;height:100%;width:0;background:var(--maroon)}
  .scrub .knob{position:absolute;top:50%;width:12px;height:12px;border-radius:50%;background:var(--maroon);transform:translate(-50%,-50%);left:0}
  .times{display:flex;justify-content:space-between;font-family:var(--sans);font-size:.66rem;letter-spacing:.06em;color:var(--muted);margin-top:6px}
  .rate{font-family:var(--sans);font-size:.66rem;letter-spacing:.08em;border:1px solid var(--ink);background:none;padding:6px 9px;cursor:pointer;color:var(--ink)}
  .rate:hover{background:var(--ink);color:var(--cream)}
  .player .links{margin-top:14px;display:flex;gap:16px}
  .player .links a{font-family:var(--sans);font-size:.68rem;letter-spacing:.1em;text-transform:uppercase;color:var(--maroon)}
  .player .links a:hover{text-decoration:underline}

  /* Transcript */
  .transcript{max-width:900px;margin:0 auto;padding:0 24px}
  .transcript details{border:1px solid rgba(26,26,26,.3);border-top:none}
  .transcript summary{font-family:var(--sans);font-size:.7rem;letter-spacing:.14em;text-transform:uppercase;color:var(--ink);padding:14px 20px;cursor:pointer;background:var(--cream-2)}
  .transcript .t-body{padding:18px 22px;font-size:1rem;color:#3a352d}

  /* Episode list */
  .section-head{max-width:1180px;margin:0 auto;padding:36px 24px 6px;display:flex;align-items:baseline;justify-content:space-between;gap:16px}
  .section-head h2{font-size:1.15rem;font-weight:400;letter-spacing:.02em}
  .section-head a{font-family:var(--sans);font-size:.7rem;letter-spacing:.14em;text-transform:uppercase;color:var(--maroon)}
  .episodes{max-width:1180px;margin:0 auto;padding:14px 24px 44px}
  .ep{display:grid;grid-template-columns:64px 1fr auto;gap:20px;align-items:center;border-top:1px solid var(--ink);padding:18px 0}
  .ep .cover{width:64px;height:64px;background:linear-gradient(155deg,#3a0f18,#6E1423);border:1px solid var(--ink);display:flex;align-items:center;justify-content:center;color:rgba(244,241,234,.8)}
  .ep .cover svg{width:20px;height:20px}
  .ep .meta .type{font-family:var(--sans);font-size:.62rem;letter-spacing:.16em;text-transform:uppercase;color:var(--maroon);display:block;margin-bottom:5px}
  .ep .meta h3{font-family:var(--serif);font-weight:400;font-size:1.22rem;line-height:1.15;margin-bottom:4px}
  .ep .meta p{font-family:var(--sans);font-size:.76rem;color:var(--muted)}
  .ep .dur{font-family:var(--sans);font-size:.72rem;letter-spacing:.08em;color:var(--muted);white-space:nowrap}
  .ep .playbtn{width:40px;height:40px;flex:none;border-radius:50%;border:1px solid var(--ink);background:none;cursor:pointer;display:flex;align-items:center;justify-content:center;color:var(--ink);transition:all .15s}
  .ep .playbtn:hover{background:var(--maroon);border-color:var(--maroon);color:var(--cream)}
  .ep .playbtn svg{width:14px;height:14px}
  .ep .right{display:flex;align-items:center;gap:16px}

  footer{background:var(--ink);color:var(--cream);margin-top:20px}
  .foot-inner{max-width:1180px;margin:0 auto;padding:48px 24px 30px;display:grid;grid-template-columns:1.4fr 1fr 1fr 1fr;gap:34px}
  .foot-brand .wm{font-family:var(--serif);font-size:1.7rem}
  .foot-brand .wm em{font-style:italic;color:#e0a4ad}
  .foot-brand p{font-family:var(--sans);font-size:.76rem;letter-spacing:.04em;color:#c9c3b7;margin-top:12px;max-width:34ch}
  .foot-col h5{font-family:var(--sans);font-size:.7rem;letter-spacing:.2em;text-transform:uppercase;color:#e0a4ad;margin-bottom:14px}
  .foot-col a{display:block;font-family:var(--sans);font-size:.86rem;color:#e9e4d9;padding:6px 0;transition:color .15s}
  .foot-col a:hover{color:#fff;text-decoration:underline}
  .foot-bottom{border-top:1px solid rgba(244,241,234,.18);margin-top:14px}
  .foot-bottom .fb{max-width:1180px;margin:0 auto;padding:18px 24px;display:flex;justify-content:space-between;flex-wrap:wrap;gap:10px;font-family:var(--sans);font-size:.7rem;letter-spacing:.08em;color:#b7b1a5;text-transform:uppercase}

  @media(max-width:820px){
    .nav-links{display:none}
    .player{grid-template-columns:1fr}
    .player .art{border-right:none;border-bottom:1px solid var(--ink);padding:26px}
    .ep{grid-template-columns:52px 1fr;gap:14px}
    .ep .right{grid-column:1/-1;justify-content:space-between}
    .foot-inner{grid-template-columns:1fr;gap:26px}
  }
</style>
